CC = gcc
CFLAGS = -g -Wall
LDFLAGS = -L.
LDLIBS = -lstack

MAIN_TARGETS = p3_e1 p3_e2 p3_e3
OPTIONAL_TARGETS = p3_e1s p3_e2s

COMMON_OBJS = radio.o music.o
QUEUE_OBJS = queue.o
LIST_OBJS = list.o
QUEUE_LIST_OBJS = queueList.o $(LIST_OBJS)

.PHONY: all optional clean run run_optional

all: $(MAIN_TARGETS)

optional: $(OPTIONAL_TARGETS)

p3_e1: p3_e1.o $(COMMON_OBJS) $(QUEUE_OBJS) libstack.a
	$(CC) $(CFLAGS) -o $@ p3_e1.o $(COMMON_OBJS) $(QUEUE_OBJS) $(LDFLAGS) $(LDLIBS)

p3_e2: p3_e2.o $(COMMON_OBJS) $(QUEUE_OBJS) libstack.a
	$(CC) $(CFLAGS) -o $@ p3_e2.o $(COMMON_OBJS) $(QUEUE_OBJS) $(LDFLAGS) $(LDLIBS)

p3_e3: p3_e3.o $(COMMON_OBJS) $(QUEUE_OBJS) $(LIST_OBJS) libstack.a
	$(CC) $(CFLAGS) -o $@ p3_e3.o $(COMMON_OBJS) $(QUEUE_OBJS) $(LIST_OBJS) $(LDFLAGS) $(LDLIBS)

p3_e1s: p3_e1.o $(COMMON_OBJS) $(QUEUE_LIST_OBJS) libstack.a
	$(CC) $(CFLAGS) -o $@ p3_e1.o $(COMMON_OBJS) $(QUEUE_LIST_OBJS) $(LDFLAGS) $(LDLIBS)

p3_e2s: p3_e2.o $(COMMON_OBJS) $(QUEUE_LIST_OBJS) libstack.a
	$(CC) $(CFLAGS) -o $@ p3_e2.o $(COMMON_OBJS) $(QUEUE_LIST_OBJS) $(LDFLAGS) $(LDLIBS)

p3_e1.o: p3_e1.c music.h queue.h radio.h

p3_e2.o: p3_e2.c radio.h

p3_e3.o: p3_e3.c list.h music.h radio.h

music.o: music.c music.h types.h

radio.o: radio.c radio.h music.h stack.h queue.h

queue.o: queue.c queue.h types.h

list.o: list.c list.h types.h

queueList.o: queueList.c queue.h list.h types.h

%.o: %.c
	$(CC) $(CFLAGS) -c $< -o $@

run: all
	@echo ">>>>>> Running p3_e1"
	./p3_e1 radio.txt
	@echo ">>>>>> Running p3_e2"
	./p3_e2 radio_bfs.txt 1 2
	@echo ">>>>>> Running p3_e3"
	./p3_e3 radio_bfs.txt

run_optional: optional
	@echo ">>>>>> Running p3_e1s"
	./p3_e1s radio.txt
	@echo ">>>>>> Running p3_e2s"
	./p3_e2s radio_bfs.txt 1 2

clean:
	rm -f *.o $(MAIN_TARGETS) $(OPTIONAL_TARGETS)
